---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { discography, allTags } from '../../../data/discography.js';

// Alpine.jsに渡すためにサーバーサイドでJSONを生成
const tracksData = discography.map(t => ({
  id:        t.id,
  title:     t.title,
  date:      t.date,
  type:      t.type,
  tags:      t.tags,
  youtube:   t.youtube   || '',
  thumbnail: t.thumbnail || '',
}));
---

<BaseLayout title="Discography">
  <section class="page-hero text-center py-16 px-4 mb-12">
    <h1 class="font-display font-bold text-5xl text-white inline-block">Discography</h1>
    <p class="text-white/60 mt-4">楽曲一覧</p>
  </section>
  
  <div class="max-w-6xl mx-auto px-4 py-16">
    <!-- Alpine.js コントローラー -->
    <div id="disco-app">

      <!-- タグ一覧 -->
      <div class="flex flex-wrap gap-2 items-center mb-3">
        <span class="text-sm font-medium text-base-content/60 mr-1">タグで絞り込み：</span>
        <button id="tag-all"
          class="badge badge-primary cursor-pointer py-3 px-3 text-sm font-medium"
        >すべて</button>
        {allTags.map(tag => (
          <button
            class="tag-btn badge badge-outline cursor-pointer py-3 px-3 text-sm font-medium transition-all"
            data-tag={tag}
          >{tag}</button>
        ))}
      </div>

      <!-- 件数 -->
      <p class="text-sm text-base-content/50 mb-4">
        <span id="disco-count">{discography.length}</span>件表示中
      </p>

      <!-- カードスクロールエリア -->
      <div style="max-height: 45vh; overflow-y: auto; padding-right: 6px;">
        <div id="disco-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {tracksData.map(track => (
            <a
              href={`/discography/${track.id}`}
              class="disco-card card bg-base-200 border border-base-300 shadow hover:shadow-xl transition-all hover:-translate-y-1 group"
              data-tags={track.tags.join(',')}
            >
              <figure class="aspect-video bg-base-300 overflow-hidden rounded-t-2xl">
                {track.youtube ? (
                  <img
                    src={`https://img.youtube.com/vi/${track.youtube}/mqdefault.jpg`}
                    alt={track.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  />
                ) : track.thumbnail ? (
                  <img
                    src={track.thumbnail}
                    alt={track.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-5xl bg-gradient-to-br from-primary/20 to-secondary/20">💿</div>
                )}
              </figure>
              <div class="card-body p-4">
                <h2 class="font-display font-semibold text-lg group-hover:text-primary transition-colors leading-snug">
                  {track.title}
                </h2>
                <div class="flex items-center gap-2 mt-1">
                  <span class={`badge badge-sm ${track.type === 'original' ? 'badge-primary' : track.type === 'arrange' ? 'badge-secondary' : 'badge-accent'}`}>
                    {track.type === 'original' ? 'オリジナル' : track.type === 'arrange' ? 'アレンジ' : '楽曲提供'}
                  </span>
                  <span class="text-xs text-base-content/40">{track.date}</span>
                </div>
                <div class="flex flex-wrap gap-1 mt-2">
                  {track.tags.map(tag => (
                    <span class="badge badge-outline badge-sm text-xs">{tag}</span>
                  ))}
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- 0件メッセージ -->
        <div id="disco-empty" class="hidden text-center py-20 text-base-content/40">
          <p class="text-4xl mb-4">🔍</p>
          <p>該当する楽曲が見つかりませんでした</p>
          <button id="disco-reset" class="btn btn-sm btn-outline mt-4">タグをリセット</button>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>

<script>
  const allBtn    = document.getElementById('tag-all');
  const tagBtns   = document.querySelectorAll('.tag-btn');
  const cards     = document.querySelectorAll('.disco-card');
  const countEl   = document.getElementById('disco-count');
  const emptyEl   = document.getElementById('disco-empty');
  const resetBtn  = document.getElementById('disco-reset');

  let activeTags = new Set();

  function applyFilter() {
    let visible = 0;
    cards.forEach(card => {
      const cardTags = (card.dataset.tags || '').split(',').filter(Boolean);
      const show = activeTags.size === 0
        || [...activeTags].every(t => cardTags.includes(t));
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    countEl.textContent = String(visible);
    emptyEl.classList.toggle('hidden', visible > 0);
  }

  function updateButtons() {
    const noneActive = activeTags.size === 0;
    allBtn.classList.toggle('badge-primary',  noneActive);
    allBtn.classList.toggle('badge-outline',  !noneActive);
    tagBtns.forEach(b => {
      const active = activeTags.has(b.dataset.tag);
      b.classList.toggle('badge-primary', active);
      b.classList.toggle('badge-outline',  !active);
    });
  }

  allBtn.addEventListener('click', () => {
    activeTags.clear();
    updateButtons();
    applyFilter();
  });

  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag;
      activeTags.has(tag) ? activeTags.delete(tag) : activeTags.add(tag);
      updateButtons();
      applyFilter();
    });
  });

  resetBtn?.addEventListener('click', () => {
    activeTags.clear();
    updateButtons();
    applyFilter();
  });
</script>
